# Normalize all line endings to LF on commit
* text=auto eol=lf

# Explicit text files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.css   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.glsl  text eol=lf
*.vert  text eol=lf
*.frag  text eol=lf
*.wgsl  text eol=lf
*.mts   text eol=lf
*.mjs   text eol=lf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.webp  binary
*.ico   binary
*.woff2 binary
*.woff  binary
